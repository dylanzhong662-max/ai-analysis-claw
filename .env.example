# 复制此文件为 .env，填入真实 Key 后运行脚本
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://api.openai-proxy.org/anthropic
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# yfinance 代理（云服务器 IP 被 Yahoo Finance 封锁时必填）
# 支持 http://host:port 或 socks5://host:port 格式
HTTPS_PROXY=

# Binance 交易 API（PAXG/USDT 链上黄金交易）
# 创建 Key 时必须：关闭提现权限，开启 IP 白名单（填服务器公网 IP）
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
