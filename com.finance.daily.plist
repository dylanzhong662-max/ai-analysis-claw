<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.finance.daily</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/zhongsongzhi/Desktop/大模型金融分析/run_daily.sh</string>
    </array>

    <!-- 每天 08:00 执行 -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/zhongsongzhi/Desktop/大模型金融分析/logs/launchd_daily.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/zhongsongzhi/Desktop/大模型金融分析/logs/launchd_daily.log</string>

    <!-- Mac 睡眠时如果错过了，唤醒后补跑 -->
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
