[Unit]
Description=Finance Analysis FastAPI Backend
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/finance-analysis/backend
EnvironmentFile=/opt/finance-analysis/.env
ExecStart=/opt/finance-analysis/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 1
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
